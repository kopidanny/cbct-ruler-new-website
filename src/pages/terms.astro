---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Terms of Use | ${SITE_TITLE}`} description="Terms of Use for CBCT Ruler" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Terms of Use – CBCT Ruler</h1>
			<p class="last-updated">Last Updated: November 2025</p>

			<p class="intro">
				By downloading, installing, or using CBCT Ruler ("the App"), you ("the user") agree to the following Terms of Use. If you do not agree, do not use the App.
			</p>

			<section class="term-section">
				<h2>1. Professional Responsibility</h2>
				<p>
					CBCT Ruler is intended only as a supportive measurement tool for trained dental professionals. It does not provide medical advice, diagnosis, treatment recommendations, or clinical decision-making.
				</p>
				<p>
					All measurements, interpretations, assessments, and any conclusions drawn from the App are entirely the responsibility of the user.
				</p>
				<p>
					You agree that you will use the App only within the scope of your own professional training, judgment, and qualifications.
				</p>
			</section>

			<section class="term-section">
				<h2>2. No Warranty & "As-Is" Provision</h2>
				<p>
					The App is provided "AS IS", without any warranties of any kind, express or implied, including but not limited to:
				</p>
				<ul>
					<li>Accuracy of measurements</li>
					<li>Fitness for a particular clinical or medical purpose</li>
					<li>Reliability of results</li>
					<li>Safety or clinical suitability</li>
				</ul>
				<p>
					We make no guarantee that any measurement, scale, or overlay within the App is correct, complete, or clinically applicable.
				</p>
			</section>

			<section class="term-section">
				<h2>3. Limitation of Liability</h2>
				<p>
					To the fullest extent permitted by law:
				</p>
				<p>
					The developers, owners, and distributors of CBCT Ruler shall not be liable for any direct, indirect, incidental, consequential, special, exemplary, or punitive damages of any kind.
				</p>
				<p>
					This includes, but is not limited to, damages related to:
				</p>
				<ul>
					<li>Clinical or surgical decisions</li>
					<li>Implant placement</li>
					<li>Restorative treatment</li>
					<li>Misinterpretation of measurements</li>
					<li>Calibration accuracy</li>
					<li>Proximity assessments (e.g., nerves, sinus, bone structure)</li>
					<li>Patient outcomes of any type</li>
				</ul>
				<p>
					You agree that all risk associated with using the App lies solely with you.
				</p>
			</section>

			<section class="term-section">
				<h2>4. No Data Collection, No Connectivity</h2>
				<p>
					The App operates entirely locally on the user's device. It does not collect, store, transmit, or share any data. PDF files accessed through the App remain on the user's device and are never uploaded or transmitted.
				</p>
				<p>
					You acknowledge that you alone are responsible for securing and managing any patient or clinical files used within the App.
				</p>
			</section>

			<section class="term-section">
				<h2>5. Accuracy & Calibration</h2>
				<p>
					All measurement results depend on the scaling of the PDF imported into the App. The user is solely responsible for ensuring that:
				</p>
				<ul>
					<li>The PDF is exported at 100% scale</li>
					<li>Calibration is performed correctly when required</li>
					<li>Measurements are verified through appropriate clinical methods</li>
				</ul>
				<p>
					We assume no responsibility for incorrect or non-calibrated measurements.
				</p>
			</section>

			<section class="term-section">
				<h2>6. User Obligations</h2>
				<p>
					By using the App, you agree that you will:
				</p>
				<ul>
					<li>Use the App only as a supplementary measurement tool</li>
					<li>Always rely on your own professional judgment</li>
					<li>Verify measurements using independent clinical methods when required</li>
					<li>Use the App in compliance with applicable laws and regulations</li>
				</ul>
			</section>

			<section class="term-section">
				<h2>7. Governing Law</h2>
				<p>
					These Terms are governed by the laws of the user's local jurisdiction. Any dispute arising from the App shall be resolved under those laws.
				</p>
			</section>

			<section class="term-section">
				<h2>8. Acceptance of Terms</h2>
				<p>
					By using CBCT Ruler, you acknowledge that you:
				</p>
				<ul>
					<li>Have read and understood these Terms</li>
					<li>Agree to use the App entirely at your own risk</li>
					<li>Fully release the developers, owners, and distributors from any and all liability</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 0.25em;
		color: var(--accent-dark);
	}
	.last-updated {
		font-size: 0.9em;
		color: rgb(var(--gray));
		margin-bottom: 2em;
	}
	.intro {
		font-size: 1.1em;
		margin-bottom: 2em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.term-section {
		margin-bottom: 2.5em;
	}
	.term-section h2 {
		font-size: 1.3em;
		color: var(--accent-dark);
		margin-bottom: 0.75em;
	}
	.term-section p {
		margin-bottom: 1em;
	}
	.term-section ul {
		margin: 0 0 1em 1.5em;
		padding: 0;
	}
	.term-section li {
		margin-bottom: 0.5em;
	}
</style>
