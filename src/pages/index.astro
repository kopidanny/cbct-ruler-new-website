---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero">
				<h1>CBCT Ruler</h1>
				<p class="tagline">Smart. Simple. Accurate.</p>
				<p class="intro">
					CBCT Ruler is a professional tool designed for implant specialists who need fast and precise measurement directly on CBCT scans — anywhere, anytime.
				</p>
				<p>
					It helps dentists measure, plan, and visualize implants before surgery without relying on third-party software.
				</p>
			</section>

			<!-- Features Section -->
			<section class="section">
				<h2 class="section-title">Main Features</h2>

				<div class="feature">
					<span class="feature-icon">📏</span>
					<p class="feature-text">Accurate digital ruler calibrated for dental CBCT files.</p>
				</div>

				<div class="feature">
					<span class="feature-icon">🧠</span>
					<p class="feature-text">AI-assisted measurement for distances and implant angles.</p>
				</div>

				<div class="feature">
					<span class="feature-icon">🦷</span>
					<p class="feature-text">Implant preview overlay to plan surgical positions.</p>
				</div>

				<div class="feature">
					<span class="feature-icon">📱</span>
					<p class="feature-text">Mobile-friendly and cloud-based, works on any device.</p>
				</div>

				<div class="feature">
					<span class="feature-icon">🔒</span>
					<p class="feature-text">Secure and private, no patient data stored.</p>
				</div>
			</section>

			<!-- Why CBCT Ruler Section -->
			<section class="section">
				<h2 class="section-title">Why CBCT Ruler</h2>
				<p>
					Traditional CBCT tools are often slow or limited to desktop software. CBCT Ruler changes that by offering a lightweight, mobile, and independent solution for everyday clinical use.
				</p>
			</section>

			<!-- Coming Soon Section -->
			<section class="section cta-section">
				<h2 class="section-title">Coming Soon</h2>
				<p>
					CBCT Ruler is currently in beta. Join the waiting list to be notified when it launches.
				</p>
				<a href="#" class="btn">📧 Join the Beta</a>
			</section>

			<!-- Contact Section -->
			<section class="section">
				<h2 class="section-title">Contact</h2>
				<p>
					Questions or collaboration inquiries:<br>
					📩 <a href="mailto:dr.sda2019@gmail.com">dr.sda2019@gmail.com</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 2em 0 3em;
		margin-bottom: 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.hero h1 {
		font-size: 3.5em;
		margin-bottom: 0.25em;
		color: var(--accent-dark);
	}
	.tagline {
		font-size: 1.5em;
		color: var(--accent);
		margin-bottom: 1.5em;
		font-weight: 700;
	}
	.intro {
		font-size: 1.15em;
		max-width: 700px;
		margin: 0 auto 1em;
	}
	.cta-section {
		background: rgb(var(--gray-light));
		padding: 2em;
		border-radius: 12px;
		text-align: center;
	}
	.cta-section .section-title {
		margin-bottom: 0.75em;
	}
	.cta-section p {
		margin-bottom: 1.5em;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 2.5em;
		}
		.tagline {
			font-size: 1.25em;
		}
	}
</style>
